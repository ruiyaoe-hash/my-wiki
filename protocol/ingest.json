{
  "protocol_id": "ingest",
  "version": "1.1.0",
  "description": "把外部内容吃进去：抓取原文、AI 摘要、生成知识页并更新索引",
  "triggers": {
    "keywords": [
      "入库",
      "ingest",
      "吃进去",
      "摄入"
    ],
    "auto": false
  },
  "inputs": {
    "required": [
      "url_or_path"
    ],
    "optional": [
      "title",
      "tags",
      "domain"
    ]
  },
  "steps": [
    {
      "id": 1,
      "action": "fetch_url",
      "params": {
        "url": "{{inputs.url_or_path}}",
        "output_dir": "source/original/"
      },
      "description": "抓取原文并存档"
    },
    {
      "id": 2,
      "action": "generate_summary",
      "params": {
        "input_file": "{{steps.1.original_path}}",
        "output_dir": "source/summaries/"
      },
      "description": "生成 AI 摘要"
    },
    {
      "id": 3,
      "action": "create_knowledge_page",
      "params": {
        "title": "{{inputs.title}}",
        "tags": "{{inputs.tags}}",
        "domain": "{{inputs.domain}}",
        "source_path": "{{steps.1.original_path}}",
        "source_url": "{{inputs.url_or_path}}",
        "output_dir": "知识库/"
      },
      "description": "创建知识页"
    },
    {
      "id": 4,
      "action": "generate_sidecar",
      "params": {
        "page_path": "{{steps.3.page_path}}",
        "output_dir": "knowledge/"
      },
      "description": "生成 metadata sidecar"
    },
    {
      "id": 5,
      "action": "update_index",
      "params": {
        "new_page_title": "{{inputs.title}}"
      },
      "description": "更新 index.md"
    }
  ],
  "raw_source": "agents/ingest-protocol.md"
}
