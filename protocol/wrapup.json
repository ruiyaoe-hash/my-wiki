{
  "protocol_id": "wrapup",
  "version": "1.0.0",
  "description": "会话收尾：更新 hot.md + log.md + state + 下次工作计划",
  "triggers": {
    "keywords": [
      "收尾",
      "结束",
      "wrapup"
    ]
  },
  "steps": [
    {
      "id": 1,
      "action": "update_hot_md",
      "params": {},
      "description": "更新 hot.md 当前状态与成果"
    },
    {
      "id": 2,
      "action": "append_log",
      "params": {
        "file": "log.md"
      },
      "description": "log.md 追加本次记录"
    },
    {
      "id": 3,
      "action": "call_manager",
      "params": {
        "method": "read",
        "file": "session.json"
      },
      "description": "读取 session"
    },
    {
      "id": 4,
      "action": "call_manager",
      "params": {
        "method": "update",
        "file": "session.json",
        "data": {"status": "ended"}
      },
      "description": "写回 session 状态"
    },
    {
      "id": 5,
      "action": "write_next_plan",
      "params": {
        "file": "下次工作计划.md"
      },
      "description": "写下次工作计划"
    }
  ],
  "raw_source": "agents/wrapup-protocol.md"
}
