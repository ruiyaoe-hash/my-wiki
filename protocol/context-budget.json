{
  "protocol_id": "context-budget",
  "version": "1.0.0",
  "description": "上下文 token 预算监控：50K 警告 / 100K 上限 / 200K 硬切",
  "triggers": {
    "auto": true,
    "poll_interval": "per_turn"
  },
  "steps": [
    {
      "id": 1,
      "action": "call_manager",
      "params": {
        "method": "get_goal"
      },
      "description": "获取 token 用量"
    },
    {
      "id": 2,
      "action": "check_threshold",
      "params": {
        "warn": 50000,
        "limit": 100000,
        "hard_cut": 200000
      },
      "description": "检查阈值"
    },
    {
      "id": 3,
      "action": "emit_warning",
      "params": {
        "condition": "tokens > warn"
      },
      "description": "发出警告"
    }
  ],
  "raw_source": "agents/context-budget.md"
}
