{
  "protocol_id": "check",
  "version": "1.0.0",
  "description": "检查知识库断链/孤儿页/stale/矛盾等问题",
  "triggers": {
    "keywords": [
      "检查",
      "lint",
      "check"
    ]
  },
  "steps": [
    {
      "id": 1,
      "action": "search_files",
      "params": {
        "dir": "knowledge/",
        "pattern": "*.json"
      },
      "description": "扫描所有 sidecar"
    },
    {
      "id": 2,
      "action": "search_files",
      "params": {
        "dir": "知识库/",
        "pattern": "*.md"
      },
      "description": "扫描知识库所有页面"
    },
    {
      "id": 3,
      "action": "check_stale",
      "params": {
        "field": "updated",
        "threshold_days": 90
      },
      "description": "检测 stale 页面"
    },
    {
      "id": 4,
      "action": "check_links",
      "params": {},
      "description": "检测断链"
    },
    {
      "id": 5,
      "action": "generate_report",
      "params": {
        "output": "reports/check-{date}.md"
      },
      "description": "生成检查报告"
    }
  ],
  "raw_source": "agents/check-protocol.md"
}
