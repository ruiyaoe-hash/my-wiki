{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dependency Graph Schema",
  "description": "节点间依赖关系：节点为 knowledge_id 或 protocol_id；A→B 表示 A depends on B（A 依赖/派生自 B）",
  "version": "0.1.0",
  "type": "object",
  "node_schema": {
    "node_id": {
      "type": "string",
      "description": "knowledge_id 或 protocol_id"
    },
    "node_type": {
      "type": "string",
      "enum": [
        "knowledge",
        "protocol",
        "source"
      ]
    },
    "label": {
      "type": "string",
      "description": "节点显示名称"
    },
    "metadata": {
      "type": "object",
      "description": "指向 knowledge/ 或 protocol/ 的 JSON sidecar"
    }
  },
  "edge_schema": {
    "source": {
      "type": "string",
      "description": "from node_id"
    },
    "target": {
      "type": "string",
      "description": "to node_id"
    },
    "relation": {
      "type": "string",
      "enum": [
        "depends_on",
        "references",
        "derived_from",
        "implements"
      ]
    }
  },
  "graph_format": {
    "description": "实际 JSON 图数据文件：节点列表 + 边列表",
    "file": "graphs/dependency.json",
    "example": {
      "nodes": [
        {
          "node_id": "agent_runtime_核心概念",
          "node_type": "knowledge",
          "label": "Agent Runtime 核心概念"
        }
      ],
      "edges": [
        {
          "source": "state_与_memory_的分离",
          "target": "agent_runtime_核心概念",
          "relation": "depends_on"
        }
      ]
    }
  }
}